# ================================================================
# Urban Traffic Management System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# --- Application ---
APP_ENV=development           # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# --- API Security ---
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database: PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://utm_user:utm_password@localhost:5432/utm_db
POSTGRES_USER=utm_user
POSTGRES_PASSWORD=utm_password
POSTGRES_DB=utm_db

# --- Database: InfluxDB (time-series) ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=tech-titan
INFLUXDB_BUCKET=traffic-metrics

# --- Cache: Redis ---
REDIS_URL=redis://localhost:6379/0

# --- IoT: MQTT Broker ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- AI Models ---
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.65
XGBOOST_MODEL_PATH=models/congestion_v2.pkl
USE_GPU=false                # Set true if CUDA available

# --- Video Streams ---
# Comma-separated RTSP URLs (one per intersection camera)
CAMERA_STREAMS=rtsp://camera1.city.local/live,rtsp://camera2.city.local/live

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin

# --- External APIs (optional) ---
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=
WAZE_API_KEY=
